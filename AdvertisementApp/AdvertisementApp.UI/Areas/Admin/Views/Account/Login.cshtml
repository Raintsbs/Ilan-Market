@model AdvertisementApp.UI.Areas.Admin.Models.AdminLoginViewModel
@{
    ViewData["Title"] = "Admin Girişi";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Girişi — İlanApp</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: "Inter", sans-serif; }
        .field-validation-error { color: #ef4444; font-size: 0.75rem; margin-top: 0.25rem; display: block; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center px-4">

    <div class="w-full max-w-sm">
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-red-600 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                <svg class="w-9 h-9 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-6-3a2 2 0 11-4 0 2 2 0 014 0zm-2 4a5 5 0 00-4.546 2.916A5.986 5.986 0 0010 16a5.986 5.986 0 004.546-2.084A5 5 0 0010 11z" clip-rule="evenodd"/>
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-gray-900">Admin Girişi</h1>
            <p class="text-sm text-gray-500 mt-1">Yönetim paneline erişmek için giriş yapın</p>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
            <form asp-area="Admin" asp-controller="Account" asp-action="Login" method="post" class="space-y-5">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div asp-validation-summary="All" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>

                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1.5">E-posta</label>
                    <input asp-for="Email" type="email" placeholder="admin@example.com"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none text-sm" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1.5">Şifre</label>
                    <input asp-for="Password" type="password" placeholder="••••••••"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none text-sm" />
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="flex items-center gap-2">
                    <input asp-for="RememberMe" type="checkbox" id="rememberMe"
                           class="w-4 h-4 text-red-600 border-gray-300 rounded focus:ring-red-500 cursor-pointer" />
                    <label for="rememberMe" class="text-sm text-gray-600 cursor-pointer">Beni hatırla</label>
                </div>

                <button type="submit"
                        class="w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-2.5 rounded-lg transition-all shadow-sm text-sm">
                    Giriş Yap
                </button>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
