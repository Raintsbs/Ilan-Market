@model IEnumerable<CategoryListDto>
@{ ViewData["Title"] = "Kategori Yönetimi"; }

<div class="flex items-center justify-between mb-6">
    <p class="text-sm text-gray-500 dark:text-gray-400">Toplam @Model.Count() kategori</p>
    <a asp-area="Admin" asp-controller="Categories" asp-action="Create"
       class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2 rounded-lg text-sm shadow-sm transition-all">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Yeni Kategori
    </a>
</div>

<div class="dm-card bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="dm-thead dm-tr bg-gray-50 border-b border-gray-200">
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide">#</th>
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide">Ad</th>
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide hidden sm:table-cell">Açıklama</th>
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide">Durum</th>
                <th class="dm-th px-5 py-3.5 text-right font-semibold text-gray-600 text-xs uppercase tracking-wide">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="dm-tr dm-tr border-b border-gray-100 hover:bg-gray-50 transition-colors">
                    <td class="dm-td-muted px-5 py-4 text-gray-400 text-xs">@item.Id</td>
                    <td class="dm-td px-5 py-4 font-medium text-gray-900">@item.Name</td>
                    <td class="dm-td-muted px-5 py-4 text-gray-500 hidden sm:table-cell">@(item.Description ?? "—")</td>
                    <td class="px-5 py-4">
                        @if (item.IsActive)
                        {
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>Aktif
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                                <span class="w-1.5 h-1.5 bg-gray-400 rounded-full"></span>Pasif
                            </span>
                        }
                    </td>
                    <td class="px-5 py-4 text-right">
                        <div class="flex items-center justify-end gap-2">
                            <a asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@item.Id"
                               class="dm-btn inline-flex items-center gap-1 text-gray-600 hover:text-gray-800 font-medium text-xs border border-gray-200 hover:border-gray-400 hover:bg-gray-50 px-3 py-1.5 rounded-lg transition-all">
                                Düzenle
                            </a>
                            <form asp-area="Admin" asp-controller="Categories" asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline" data-confirm-delete>
                                @Html.AntiForgeryToken()
                                <button type="submit" class="inline-flex items-center gap-1 text-red-600 hover:text-red-800 font-medium text-xs border border-red-200 hover:border-red-400 hover:bg-red-50 px-3 py-1.5 rounded-lg transition-all">
                                    Sil
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="dm-td-muted px-5 py-16 text-center text-gray-400">Henüz kategori eklenmemiş.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
