@using AdvertisementApp.UI.Areas.Admin.Models
@model List<AdminUserViewModel>
@{ ViewData["Title"] = "Kullanıcı Yönetimi"; }

<div class="flex items-center justify-between mb-6">
    <p class="text-sm text-gray-500 dark:text-gray-400">Toplam <strong>@Model.Count</strong> kullanıcı</p>
    <span id="liveIndicator" class="hidden items-center gap-1.5 text-xs text-green-600 font-medium">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
        Canlı
    </span>
</div>

<div class="dm-card bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="dm-thead dm-tr bg-gray-50 border-b border-gray-200">
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide">#</th>
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide">Ad Soyad</th>
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide">E-posta</th>
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide hidden md:table-cell">Telefon</th>
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide">Rol</th>
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide hidden sm:table-cell">E-posta Onayı</th>
                <th class="dm-th px-5 py-3.5 text-right font-semibold text-gray-600 text-xs uppercase tracking-wide">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr class="dm-tr border-b border-gray-100 hover:bg-gray-50 transition-colors">
                    <td class="dm-td-muted px-5 py-4 text-gray-400 text-xs">@user.Id</td>
                    <td class="px-5 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 @(user.IsAdmin ? "bg-red-100" : "bg-blue-100")">
                                <span class="text-xs font-bold @(user.IsAdmin ? "text-red-700" : "text-blue-700")">
                                    @(user.FirstName.Length > 0 ? user.FirstName[0].ToString().ToUpper() : "?")
                                </span>
                            </div>
                            <span class="dm-td font-medium text-gray-900">@user.FullName</span>
                        </div>
                    </td>
                    <td class="dm-td px-5 py-4 text-gray-600">@user.Email</td>
                    <td class="dm-td-muted px-5 py-4 text-gray-500 hidden md:table-cell">@(user.PhoneNumber ?? "—")</td>
                    <td class="px-5 py-4">
                        @foreach (var role in user.Roles)
                        {
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold @(role == "Admin" ? "bg-red-100 text-red-700" : "bg-blue-100 text-blue-700")">
                                @role
                            </span>
                        }
                    </td>
                    <td class="px-5 py-4 hidden sm:table-cell">
                        @if (user.EmailConfirmed)
                        {
                            <span class="inline-flex items-center gap-1 text-green-700 text-xs font-medium">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                                Onaylı
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1 text-gray-400 text-xs font-medium">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                Onaysız
                            </span>
                        }
                    </td>
                    <td class="px-5 py-4 text-right">
                        @if (!user.IsAdmin)
                        {
                            <div class="flex items-center justify-end gap-2">
                                <form asp-area="Admin" asp-controller="Users" asp-action="ToggleRole" asp-route-id="@user.Id" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex items-center gap-1 text-purple-600 hover:text-purple-800 font-medium text-xs border border-purple-200 hover:border-purple-400 hover:bg-purple-50 px-3 py-1.5 rounded-lg transition-all">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                                        Admin Yap
                                    </button>
                                </form>
                                <form asp-area="Admin" asp-controller="Users" asp-action="Delete" asp-route-id="@user.Id" method="post" class="inline" data-confirm-delete>
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex items-center gap-1 text-red-600 hover:text-red-800 font-medium text-xs border border-red-200 hover:border-red-400 hover:bg-red-50 px-3 py-1.5 rounded-lg transition-all">
                                        Sil
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            var currentEmail = User.Identity?.Name;
                            if (user.Email != currentEmail)
                            {
                                <form asp-area="Admin" asp-controller="Users" asp-action="ToggleRole" asp-route-id="@user.Id" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dm-btn inline-flex items-center gap-1 text-gray-500 hover:text-gray-700 font-medium text-xs border border-gray-200 hover:border-gray-400 hover:bg-gray-50 px-3 py-1.5 rounded-lg transition-all">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                        User Yap
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="dm-td-muted text-xs text-gray-400 italic">Korumalı</span>
                            }
                        }
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="dm-td-muted px-5 py-16 text-center text-gray-400">Kullanıcı bulunamadı.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    (function () {
        var indicator = document.getElementById('liveIndicator');
        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/notification")
            .withAutomaticReconnect()
            .build();
        connection.on("OnChange", function (type) {
            if (type === "user") window.location.reload();
        });
        connection.start().then(function () {
            if (indicator) { indicator.classList.remove('hidden'); indicator.classList.add('inline-flex'); }
        }).catch(function (err) { console.warn("SignalR:", err); });
    })();
</script>
}
