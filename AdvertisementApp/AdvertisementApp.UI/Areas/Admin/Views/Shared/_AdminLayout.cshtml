<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin Paneli</title>
    <script>
        (function () {
            var theme = localStorage.getItem('theme') || 'light';
            document.documentElement.classList.toggle('dark', theme === 'dark');
        })();
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { darkMode: 'class' };
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: "Inter", sans-serif; }
        .field-validation-error { color: #ef4444; font-size: 0.75rem; margin-top: 0.25rem; display: block; }
        .input-validation-error { border-color: #ef4444 !important; }
        .nav-link.active { background-color: #1e40af; color: #fff; }

        /* Dark mode — tablo ve kart arka planları */
        html.dark .dm-card   { background-color: #1f2937 !important; border-color: #374151 !important; }
        html.dark .dm-thead  { background-color: rgba(55,65,81,0.5) !important; border-color: #374151 !important; }
        html.dark .dm-tr     { border-color: #374151 !important; }
        html.dark .dm-tr:hover { background-color: rgba(55,65,81,0.4) !important; }
        html.dark .dm-td     { color: #e5e7eb !important; }
        html.dark .dm-td-muted { color: #9ca3af !important; }
        html.dark .dm-th     { color: #d1d5db !important; }
        html.dark .dm-input  { background-color: #374151 !important; border-color: #4b5563 !important; color: #f3f4f6 !important; }
        html.dark .dm-btn    { background-color: #374151 !important; border-color: #4b5563 !important; color: #d1d5db !important; }
        html.dark .dm-btn:hover { background-color: #4b5563 !important; }
    </style>
</head>
<body class="bg-gray-100 dark:bg-gray-950 min-h-screen flex transition-colors duration-200">

    @* Sidebar *@
    <aside class="w-64 min-h-screen bg-gray-900 dark:bg-gray-950 text-white flex flex-col fixed top-0 left-0 z-40 border-r border-gray-800">
        <div class="flex items-center gap-3 px-6 py-5 border-b border-gray-700">
            <div class="w-8 h-8 bg-red-600 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-6-3a2 2 0 11-4 0 2 2 0 014 0zm-2 4a5 5 0 00-4.546 2.916A5.986 5.986 0 0010 16a5.986 5.986 0 004.546-2.084A5 5 0 0010 11z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div>
                <p class="font-bold text-sm">Admin Paneli</p>
                <p class="text-xs text-gray-400">İlanApp Yönetimi</p>
            </div>
        </div>

        <nav class="flex-1 px-3 py-4 space-y-1">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
               class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-white transition-all @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
                Dashboard
            </a>

            <a asp-area="Admin" asp-controller="Advertisements" asp-action="Index"
               class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-white transition-all @(ViewContext.RouteData.Values["controller"]?.ToString() == "Advertisements" ? "active" : "")">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                İlanlar
            </a>

            <a asp-area="Admin" asp-controller="Advertisements" asp-action="Pending"
               class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-white transition-all @(ViewContext.RouteData.Values["action"]?.ToString() == "Pending" ? "active" : "")">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="flex-1">Onay Bekleyenler</span>
            </a>

            <a asp-area="Admin" asp-controller="Categories" asp-action="Index"
               class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-white transition-all @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                </svg>
                Kategoriler
            </a>

            <a asp-area="Admin" asp-controller="Users" asp-action="Index"
               class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-white transition-all @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                Kullanıcılar
            </a>

            <div class="pt-4 mt-4 border-t border-gray-700">
                <a asp-area="" asp-controller="Home" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white transition-all">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                    Siteye Dön
                </a>
            </div>
        </nav>

        <div class="px-4 py-4 border-t border-gray-700">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 bg-red-700 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-white font-bold text-xs">A</span>
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-medium text-white truncate">@User.Identity?.Name</p>
                    <p class="text-xs text-red-400 font-semibold">Admin</p>
                </div>
            </div>
            <a asp-area="Admin" asp-controller="Account" asp-action="Logout"
               class="w-full text-left flex items-center gap-2 px-3 py-2 rounded-lg text-xs text-gray-400 hover:bg-gray-800 hover:text-white transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                Çıkış Yap
            </a>
        </div>
    </aside>

    @* Main Content *@
    <div class="flex-1 ml-64 flex flex-col min-h-screen">
        <header class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-6 py-4 flex items-center justify-between sticky top-0 z-30">
            <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100">@ViewData["Title"]</h2>
            <div class="flex items-center gap-3">
                <button onclick="toggleTheme()"
                        class="w-8 h-8 flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-500 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600 transition-all"
                        title="Tema değiştir">
                    <svg id="adminIconSun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
                    </svg>
                    <svg id="adminIconMoon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                    </svg>
                </button>
                <span class="text-xs text-gray-400 dark:text-gray-500">@DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</span>
            </div>
        </header>

        @if (TempData["Success"] != null)
        {
            <div class="mx-6 mt-4">
                <div class="flex items-center gap-3 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 text-green-800 dark:text-green-300 px-4 py-3 rounded-lg text-sm">
                    <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    @TempData["Success"]
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="mx-6 mt-4">
                <div class="flex items-center gap-3 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 text-red-800 dark:text-red-300 px-4 py-3 rounded-lg text-sm">
                    <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    @TempData["Error"]
                </div>
            </div>
        }

        <main class="flex-1 p-6 bg-gray-100 dark:bg-gray-900">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Tema toggle
        function toggleTheme() {
            var isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            var sun = document.getElementById('adminIconSun');
            var moon = document.getElementById('adminIconMoon');
            if (sun) sun.classList.toggle('hidden', !isDark);
            if (moon) moon.classList.toggle('hidden', isDark);
        }

        // Sayfa yüklenince ikonu ayarla
        (function () {
            var isDark = document.documentElement.classList.contains('dark');
            var sun = document.getElementById('adminIconSun');
            var moon = document.getElementById('adminIconMoon');
            if (sun) sun.classList.toggle('hidden', !isDark);
            if (moon) moon.classList.toggle('hidden', isDark);
        })();
    </script>

    @* Silme Onay Modalı *@
    <div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center">
        <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="deleteModalBackdrop"></div>
        <div class="relative bg-white dark:bg-gray-800 rounded-2xl shadow-xl w-full max-w-sm mx-4 p-6">
            <div class="flex flex-col items-center text-center gap-4">
                <div class="w-14 h-14 bg-red-100 dark:bg-red-900/40 rounded-full flex items-center justify-center">
                    <svg class="w-7 h-7 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white">Silmek istediğinize emin misiniz?</h3>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Bu işlem geri alınamaz.</p>
                </div>
                <div class="flex gap-3 w-full mt-2">
                    <button id="deleteCancelBtn" class="flex-1 px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-semibold text-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-all">Vazgeç</button>
                    <button id="deleteConfirmBtn" class="flex-1 px-4 py-2.5 rounded-lg bg-red-600 hover:bg-red-700 text-white font-semibold text-sm transition-all">Evet, Sil</button>
                </div>
            </div>
        </div>
    </div>
    <script>
        (function () {
            var modal = document.getElementById('deleteModal');
            var confirmBtn = document.getElementById('deleteConfirmBtn');
            var cancelBtn = document.getElementById('deleteCancelBtn');
            var backdrop = document.getElementById('deleteModalBackdrop');
            var pendingForm = null;
            function openModal(form) { pendingForm = form; modal.classList.remove('hidden'); modal.classList.add('flex'); }
            function closeModal() { modal.classList.add('hidden'); modal.classList.remove('flex'); pendingForm = null; }
            document.querySelectorAll('form[data-confirm-delete]').forEach(function (form) {
                form.addEventListener('submit', function (e) { e.preventDefault(); openModal(form); });
            });
            confirmBtn.addEventListener('click', function () { if (pendingForm) pendingForm.submit(); closeModal(); });
            cancelBtn.addEventListener('click', closeModal);
            backdrop.addEventListener('click', closeModal);
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeModal(); });
        })();
    </script>
</body>
</html>
