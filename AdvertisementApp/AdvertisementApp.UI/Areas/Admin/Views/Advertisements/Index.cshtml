@model PagedResult<AdvertisementListDto>
@{ ViewData["Title"] = "İlan Yönetimi"; var filter = ViewBag.Filter as AdvertisementFilterDto ?? new AdvertisementFilterDto(); }

<div class="dm-card bg-white rounded-xl border border-gray-200 shadow-sm p-4 mb-5">
    <form method="get" asp-area="Admin" asp-controller="Advertisements" asp-action="Index" class="flex flex-col sm:flex-row gap-3">
        <div class="flex-1 relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input type="text" name="Search" value="@filter.Search" placeholder="Başlık ara..."
                   class="dm-input w-full pl-9 pr-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none text-sm bg-white" />
        </div>
        <select name="CategoryId" asp-items="ViewBag.Categories"
                class="dm-input w-full sm:w-48 px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none text-sm bg-white">
            <option value="">Tüm Kategoriler</option>
        </select>
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-lg text-sm transition-all">Filtrele</button>
    </form>
</div>

<div class="dm-card bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="dm-thead dm-tr bg-gray-50 border-b border-gray-200">
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide">#</th>
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide">Başlık</th>
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide hidden md:table-cell">Kategori</th>
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide">Durum</th>
                <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide hidden lg:table-cell">Tarih</th>
                <th class="dm-th px-5 py-3.5 text-right font-semibold text-gray-600 text-xs uppercase tracking-wide">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Items.Any())
            {
                @foreach (var item in Model.Items)
                {
                    <tr class="dm-tr border-b border-gray-100 hover:bg-gray-50 transition-colors">
                        <td class="dm-td-muted px-5 py-4 text-gray-400 text-xs">@item.Id</td>
                        <td class="dm-td px-5 py-4 font-medium text-gray-900 max-w-[200px] truncate">@item.Title</td>
                        <td class="px-5 py-4 hidden md:table-cell">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">@item.CategoryName</span>
                        </td>
                        <td class="px-5 py-4">
                            @if (item.IsActive)
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                    <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>Aktif
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                                    <span class="w-1.5 h-1.5 bg-gray-400 rounded-full"></span>Pasif
                                </span>
                            }
                        </td>
                        <td class="dm-td-muted px-5 py-4 text-gray-500 text-xs hidden lg:table-cell">@item.CreatedTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="px-5 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <form asp-area="Admin" asp-controller="Advertisements" asp-action="ToggleActive" asp-route-id="@item.Id" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex items-center gap-1 text-blue-600 hover:text-blue-800 font-medium text-xs border border-blue-200 hover:border-blue-400 hover:bg-blue-50 px-3 py-1.5 rounded-lg transition-all">
                                        @(item.IsActive ? "Pasif Yap" : "Aktif Yap")
                                    </button>
                                </form>
                                <form asp-area="Admin" asp-controller="Advertisements" asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline" data-confirm-delete>
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex items-center gap-1 text-red-600 hover:text-red-800 font-medium text-xs border border-red-200 hover:border-red-400 hover:bg-red-50 px-3 py-1.5 rounded-lg transition-all">
                                        Sil
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="dm-td-muted px-5 py-16 text-center text-gray-400">Henüz ilan bulunamadı.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model != null && Model.TotalPages > 1)
{
    <div class="flex items-center justify-center gap-1 mt-5">
        @for (var p = 1; p <= Model.TotalPages; p++)
        {
            <a asp-area="Admin" asp-controller="Advertisements" asp-action="Index"
               asp-route-page="@p" asp-route-search="@filter.Search" asp-route-categoryId="@filter.CategoryId"
               class="@(p == Model.Page ? "bg-blue-600 text-white" : "dm-btn bg-white text-gray-700 hover:bg-gray-50 border border-gray-300") px-3 py-1.5 rounded-lg text-sm font-medium transition-all">
                @p
            </a>
        }
    </div>
}

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    (function () {
        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/notification")
            .withAutomaticReconnect()
            .build();
        connection.on("OnChange", function (type) {
            if (type === "advertisement") window.location.reload();
        });
        connection.start().catch(function (err) { console.warn("SignalR:", err); });
    })();
</script>
}
