@model List<AdvertisementListDto>
@{ ViewData["Title"] = "Onay Bekleyen İlanlar"; }

@if (!Model.Any())
{
    <div class="dm-card bg-white rounded-xl border border-gray-200 shadow-sm p-16 text-center">
        <svg class="w-12 h-12 mx-auto mb-3 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="dm-td-muted font-medium text-gray-500">Onay bekleyen ilan yok.</p>
    </div>
}
else
{
    <div class="dm-card bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="dm-thead dm-tr bg-amber-50 border-b border-amber-100">
                    <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide">#</th>
                    <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide">Başlık</th>
                    <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide hidden md:table-cell">Kategori</th>
                    <th class="dm-th text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide hidden lg:table-cell">Tarih</th>
                    <th class="dm-th px-5 py-3.5 text-right font-semibold text-gray-600 text-xs uppercase tracking-wide">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="dm-tr border-b border-gray-100 hover:bg-gray-50 transition-colors">
                        <td class="dm-td-muted px-5 py-4 text-gray-400 text-xs">@item.Id</td>
                        <td class="px-5 py-4">
                            <p class="dm-td font-medium text-gray-900">@item.Title</p>
                            <p class="dm-td-muted text-xs text-gray-400 mt-0.5 line-clamp-1">@item.Description</p>
                        </td>
                        <td class="px-5 py-4 hidden md:table-cell">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">@item.CategoryName</span>
                        </td>
                        <td class="dm-td-muted px-5 py-4 text-gray-500 text-xs hidden lg:table-cell">@item.CreatedTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="px-5 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <form asp-area="Admin" asp-controller="Advertisements" asp-action="Approve" asp-route-id="@item.Id" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex items-center gap-1 text-green-700 hover:text-green-900 font-medium text-xs border border-green-200 hover:border-green-400 hover:bg-green-50 px-3 py-1.5 rounded-lg transition-all">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                                        Onayla
                                    </button>
                                </form>
                                <form asp-area="Admin" asp-controller="Advertisements" asp-action="Reject" asp-route-id="@item.Id" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex items-center gap-1 text-red-600 hover:text-red-800 font-medium text-xs border border-red-200 hover:border-red-400 hover:bg-red-50 px-3 py-1.5 rounded-lg transition-all">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                        Reddet
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    (function () {
        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/notification")
            .withAutomaticReconnect()
            .build();
        connection.on("OnChange", function (type) {
            if (type === "advertisement") window.location.reload();
        });
        connection.start().catch(function (err) { console.warn("SignalR:", err); });
    })();
</script>
}
