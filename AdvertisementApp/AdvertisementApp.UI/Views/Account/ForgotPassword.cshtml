@using AdvertisementApp.UI.Models
@model ForgotPasswordViewModel
@{ ViewData["Title"] = "Şifremi Unuttum"; }

<div class="min-h-[calc(100vh-8rem)] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-gray-900">Şifremi Unuttum</h1>
            <p class="text-sm text-gray-500 mt-1">E-posta adresinize sıfırlama bağlantısı göndereceğiz.</p>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
            <form asp-action="ForgotPassword" method="post" class="space-y-5">
                @Html.AntiForgeryToken()
                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1.5">E-posta Adresi</label>
                    <input asp-for="Email" type="email" placeholder="ornek@email.com"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>
                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 rounded-lg transition-all shadow-sm text-sm">
                    Sıfırlama Bağlantısı Gönder
                </button>
            </form>
        </div>

        <p class="text-center text-sm text-gray-500 mt-6">
            <a asp-action="Login" class="text-blue-600 hover:text-blue-800 font-semibold inline-flex items-center gap-1 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Giriş sayfasına dön
            </a>
        </p>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
