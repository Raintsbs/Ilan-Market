@using AdvertisementApp.UI.Models
@model LoginViewModel
@{ ViewData["Title"] = "Giriş"; }

<div class="min-h-[calc(100vh-8rem)] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-gray-900">Tekrar hoş geldiniz</h1>
            <p class="text-sm text-gray-500 mt-1">Hesabınıza giriş yapın</p>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
            <form asp-action="Login" method="post" class="space-y-5">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div asp-validation-summary="All" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>

                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1.5">E-posta</label>
                    <input asp-for="Email" type="email" placeholder="ornek@email.com"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div>
                    <div class="flex items-center justify-between mb-1.5">
                        <label asp-for="Password" class="block text-sm font-medium text-gray-700">Şifre</label>
                        <a asp-action="ForgotPassword" class="text-xs text-blue-600 hover:text-blue-800 font-medium transition-colors">Şifremi unuttum</a>
                    </div>
                    <input asp-for="Password" type="password" placeholder="••••••••"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm" />
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="flex items-center gap-2">
                    <input asp-for="RememberMe" type="checkbox" id="rememberMe"
                           class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 cursor-pointer" />
                    <label for="rememberMe" class="text-sm text-gray-600 cursor-pointer">Beni hatırla</label>
                </div>

                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 rounded-lg transition-all shadow-sm text-sm">
                    Giriş Yap
                </button>
            </form>
        </div>

        <p class="text-center text-sm text-gray-500 mt-6">
            Hesabınız yok mu?
            <a asp-action="Register" class="text-blue-600 hover:text-blue-800 font-semibold transition-colors">Kayıt olun</a>
        </p>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
