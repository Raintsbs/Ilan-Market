@using AdvertisementApp.UI.Models
@model ChangePasswordViewModel
@{ ViewData["Title"] = "Şifre Değiştir"; }

<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6">
        <a asp-action="Index" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-blue-600 transition-colors mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Profilime Dön
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Şifre Değiştir</h1>
        <p class="text-sm text-gray-500 mt-0.5">Güvenliğiniz için güçlü bir şifre seçin.</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
        <form asp-action="ChangePassword" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>

            <div>
                <label asp-for="CurrentPassword" class="block text-sm font-medium text-gray-700 mb-1.5"></label>
                <input asp-for="CurrentPassword" type="password" placeholder="••••••••"
                       class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none text-sm" />
                <span asp-validation-for="CurrentPassword" class="field-validation-error"></span>
            </div>

            <div>
                <label asp-for="NewPassword" class="block text-sm font-medium text-gray-700 mb-1.5"></label>
                <input asp-for="NewPassword" type="password" placeholder="••••••••"
                       class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none text-sm" />
                <span asp-validation-for="NewPassword" class="field-validation-error"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700 mb-1.5"></label>
                <input asp-for="ConfirmPassword" type="password" placeholder="••••••••"
                       class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none text-sm" />
                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>

            <div class="flex items-center gap-3 pt-2">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-lg text-sm transition-all shadow-sm">
                    Şifremi Güncelle
                </button>
                <a asp-action="Index" class="bg-white hover:bg-gray-50 text-gray-700 font-semibold px-6 py-2.5 rounded-lg border border-gray-300 text-sm transition-all">
                    İptal
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
