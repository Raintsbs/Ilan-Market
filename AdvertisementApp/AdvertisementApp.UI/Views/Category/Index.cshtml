@using AdvertisementApp.Dtos.CategoryDtos
@model IEnumerable<CategoryListDto>
@{ ViewData["Title"] = "Kategoriler"; }

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Kategoriler</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">Tüm ilan kategorilerini buradan görüntüleyebilirsiniz.</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-lg text-sm shadow-sm transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Yeni Kategori
            </a>
        }
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="bg-gray-50 dark:bg-gray-700/50 border-b border-gray-200 dark:border-gray-700">
                    <th class="text-left px-5 py-3.5 font-semibold text-gray-600 dark:text-gray-300 text-xs uppercase tracking-wide">Ad</th>
                    <th class="text-left px-5 py-3.5 font-semibold text-gray-600 dark:text-gray-300 text-xs uppercase tracking-wide hidden sm:table-cell">Açıklama</th>
                    <th class="text-left px-5 py-3.5 font-semibold text-gray-600 dark:text-gray-300 text-xs uppercase tracking-wide">Durum</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th class="px-5 py-3.5 text-right font-semibold text-gray-600 dark:text-gray-300 text-xs uppercase tracking-wide">İşlemler</th>
                    }
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/40 transition-colors">
                        <td class="px-5 py-4 font-medium text-gray-900 dark:text-gray-100">@item.Name</td>
                        <td class="px-5 py-4 text-gray-500 dark:text-gray-400 hidden sm:table-cell">@item.Description</td>
                        <td class="px-5 py-4">
                            @if (item.IsActive)
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300">
                                    <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>Aktif
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">
                                    <span class="w-1.5 h-1.5 bg-gray-400 rounded-full"></span>Pasif
                                </span>
                            }
                        </td>
                        @if (User.IsInRole("Admin"))
                        {
                            <td class="px-5 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="inline-flex items-center gap-1 text-gray-600 dark:text-gray-300 hover:text-gray-800 font-medium text-xs border border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 px-3 py-1.5 rounded-lg transition-all">
                                        Düzenle
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline" data-confirm-delete>
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="inline-flex items-center gap-1 text-red-600 dark:text-red-400 hover:text-red-800 font-medium text-xs border border-red-200 dark:border-red-700 hover:bg-red-50 dark:hover:bg-red-900/30 px-3 py-1.5 rounded-lg transition-all">
                                            Sil
                                        </button>
                                    </form>
                                </div>
                            </td>
                        }
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="px-5 py-16 text-center">
                            <p class="font-medium text-gray-500 dark:text-gray-400">Henüz kategori eklenmemiş.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
