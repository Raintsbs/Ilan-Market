@using AdvertisementApp.Dtos.AdvertisementDtos
@model List<AdvertisementListDto>
@{ ViewData["Title"] = "Favorilerim"; }

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Favorilerim</h1>
            <p class="text-sm text-gray-500 mt-0.5">Favori olarak işaretlediğiniz ilanlar.</p>
        </div>
        <span class="text-sm text-gray-500">@Model.Count ilan</span>
    </div>

    @if (Model.Any())
    {
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-200">
                        <th class="text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide">Başlık</th>
                        <th class="text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide hidden sm:table-cell">Kategori</th>
                        <th class="text-left px-5 py-3.5 font-semibold text-gray-600 text-xs uppercase tracking-wide hidden md:table-cell">Durum</th>
                        <th class="px-5 py-3.5 text-right font-semibold text-gray-600 text-xs uppercase tracking-wide">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-5 py-4">
                                <div class="flex items-center gap-3">
                                    @if (!string.IsNullOrEmpty(item.ImagePath))
                                    {
                                        <img src="@item.ImagePath" alt="@item.Title" class="w-10 h-10 object-cover rounded-lg flex-shrink-0" />
                                    }
                                    else
                                    {
                                        <div class="w-10 h-10 bg-gray-100 rounded-lg flex-shrink-0 flex items-center justify-center">
                                            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                        </div>
                                    }
                                    <span class="font-medium text-gray-900">@item.Title</span>
                                </div>
                            </td>
                            <td class="px-5 py-4 hidden sm:table-cell">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">@item.CategoryName</span>
                            </td>
                            <td class="px-5 py-4 hidden md:table-cell">
                                @if (item.IsActive)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>Aktif
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                                        <span class="w-1.5 h-1.5 bg-gray-400 rounded-full"></span>Pasif
                                    </span>
                                }
                            </td>
                            <td class="px-5 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-controller="Advertisement" asp-action="Details" asp-route-id="@item.Id"
                                       class="inline-flex items-center gap-1 text-blue-600 hover:text-blue-800 font-medium text-xs border border-blue-200 hover:border-blue-400 hover:bg-blue-50 px-3 py-1.5 rounded-lg transition-all">
                                        Detay
                                    </a>
                                    <form asp-controller="Favorite" asp-action="Toggle" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="advertisementId" value="@item.Id" />
                                        <input type="hidden" name="returnUrl" value="/Favorite" />
                                        <button type="submit"
                                                class="inline-flex items-center gap-1 text-red-500 hover:text-red-700 font-medium text-xs border border-red-200 hover:border-red-400 hover:bg-red-50 px-3 py-1.5 rounded-lg transition-all">
                                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/>
                                            </svg>
                                            Kaldır
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-16 text-center">
            <svg class="w-12 h-12 mx-auto mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
            <p class="font-medium text-gray-500">Henüz favori ilanınız yok.</p>
            <a asp-controller="Advertisement" asp-action="Index" class="inline-block mt-3 text-sm text-blue-600 hover:underline">İlanlara göz at</a>
        </div>
    }
</div>
