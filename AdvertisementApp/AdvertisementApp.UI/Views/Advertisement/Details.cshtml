@using AdvertisementApp.Dtos.AdvertisementDtos
@model AdvertisementListDto
@{ ViewData["Title"] = Model.Title; var similarAds = ViewBag.SimilarAds as List<AdvertisementListDto> ?? new List<AdvertisementListDto>(); }

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
        <a asp-controller="Home" asp-action="Index" class="hover:text-blue-600 transition-colors">Ana Sayfa</a>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a asp-controller="Advertisement" asp-action="Index" class="hover:text-blue-600 transition-colors">İlanlar</a>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-gray-900 font-medium truncate">@Model.Title</span>
    </nav>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-100 flex items-start justify-between gap-4">
            <div>
                <h1 class="text-xl font-bold text-gray-900">@Model.Title</h1>
                <p class="text-xs text-gray-400 mt-1">İlan #@Model.Id</p>
            </div>
            @if (Model.IsActive)
            {
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-800 flex-shrink-0">
                    <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>Aktif
                </span>
            }
            else
            {
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-500 flex-shrink-0">
                    <span class="w-1.5 h-1.5 bg-gray-400 rounded-full"></span>Pasif
                </span>
            }
        </div>

        <dl class="divide-y divide-gray-50">
            <div class="px-6 py-4 flex items-start gap-4">
                <dt class="text-sm font-medium text-gray-500 w-32 flex-shrink-0 pt-0.5">Kategori</dt>
                <dd><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">@Model.CategoryName</span></dd>
            </div>
            <div class="px-6 py-4 flex items-start gap-4">
                <dt class="text-sm font-medium text-gray-500 w-32 flex-shrink-0 pt-0.5">Açıklama</dt>
                <dd class="text-sm text-gray-900">@Model.Description</dd>
            </div>
            <div class="px-6 py-4 flex items-start gap-4">
                <dt class="text-sm font-medium text-gray-500 w-32 flex-shrink-0 pt-0.5">İçerik</dt>
                <dd class="text-sm text-gray-900 leading-relaxed">@Model.Content</dd>
            </div>
            <div class="px-6 py-4 flex items-start gap-4">
                <dt class="text-sm font-medium text-gray-500 w-32 flex-shrink-0 pt-0.5">Görsel</dt>
                <dd>
                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <img src="@Model.ImagePath" alt="@Model.Title" class="w-48 h-32 object-cover rounded-lg border border-gray-200" />
                    }
                    else
                    {
                        <div class="w-48 h-32 bg-gray-100 rounded-lg border border-gray-200 flex flex-col items-center justify-center gap-2">
                            <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            <span class="text-xs text-gray-400">Görsel yok</span>
                        </div>
                    }
                </dd>
            </div>
            <div class="px-6 py-4 flex items-start gap-4">
                <dt class="text-sm font-medium text-gray-500 w-32 flex-shrink-0 pt-0.5">Oluşturulma</dt>
                <dd class="text-sm text-gray-900">@Model.CreatedTime.ToString("dd.MM.yyyy HH:mm")</dd>
            </div>
        </dl>

        <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex items-center gap-3">
            <a asp-action="Index" class="inline-flex items-center gap-2 bg-white hover:bg-gray-100 text-gray-700 font-semibold px-4 py-2 rounded-lg border border-gray-300 text-sm transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Listeye Dön
            </a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                var isFav = (bool)(ViewBag.IsFavorite ?? false);
                <form asp-controller="Favorite" asp-action="Toggle" method="post" class="inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="advertisementId" value="@Model.Id" />
                    <button type="submit"
                            class="inline-flex items-center gap-2 font-semibold px-4 py-2 rounded-lg text-sm transition-all @(isFav ? "bg-red-50 text-red-600 border border-red-200 hover:bg-red-100" : "bg-white text-gray-600 border border-gray-300 hover:bg-gray-50")">
                        <svg class="w-4 h-4" fill="@(isFav ? "currentColor" : "none")" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                        </svg>
                        @(isFav ? "Favorilerden Kaldır" : "Favorilere Ekle")
                    </button>
                </form>
            }
            @if (User.Identity?.IsAuthenticated == true &&
                 (User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == Model.UserId.ToString() || User.IsInRole("Admin")))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id"
                   class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2 rounded-lg text-sm transition-all">
                    Düzenle
                </a>
            }
        </div>
    </div>

    @if (similarAds.Any())
    {
        <div class="mt-10">
            <h2 class="text-lg font-bold text-gray-900 mb-4">
                <span class="inline-flex items-center gap-2">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">@Model.CategoryName</span>
                    kategorisinden benzer ilanlar
                </span>
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                @foreach (var ad in similarAds)
                {
                    <a asp-action="Details" asp-route-id="@ad.Id"
                       class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 hover:shadow-md hover:border-blue-200 transition-all flex gap-4 group">
                        @if (!string.IsNullOrEmpty(ad.ImagePath))
                        {
                            <img src="@ad.ImagePath" alt="@ad.Title" class="w-20 h-16 object-cover rounded-lg flex-shrink-0" />
                        }
                        else
                        {
                            <div class="w-20 h-16 bg-gray-100 rounded-lg flex-shrink-0 flex items-center justify-center">
                                <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            </div>
                        }
                        <div class="min-w-0">
                            <p class="font-semibold text-gray-900 text-sm truncate group-hover:text-blue-600 transition-colors">@ad.Title</p>
                            <p class="text-xs text-gray-500 mt-1 line-clamp-2">@ad.Description</p>
                            <p class="text-xs text-gray-400 mt-2">@ad.CreatedTime.ToString("dd.MM.yyyy")</p>
                        </div>
                    </a>
                }
            </div>
        </div>
    }
</div>
