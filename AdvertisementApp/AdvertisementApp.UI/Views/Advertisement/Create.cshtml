@using AdvertisementApp.UI.Models
@model AdvertisementCreateViewModel
@{ ViewData["Title"] = "Yeni İlan Ver"; }

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Yeni İlan Ver</h1>
        <p class="text-sm text-gray-500 mt-0.5">Aşağıdaki formu doldurarak ilanınızı yayınlayın.</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
        <form asp-action="Create" method="post" enctype="multipart/form-data" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>

            <div>
                <label asp-for="CategoryId" class="block text-sm font-medium text-gray-700 mb-1.5"></label>
                <select asp-for="CategoryId" asp-items="ViewBag.Categories"
                        class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm bg-white">
                    <option value="">-- Kategori Seçin --</option>
                </select>
                <span asp-validation-for="CategoryId" class="field-validation-error"></span>
            </div>

            <div>
                <label asp-for="Title" class="block text-sm font-medium text-gray-700 mb-1.5"></label>
                <input asp-for="Title" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm" placeholder="İlan başlığı" />
                <span asp-validation-for="Title" class="field-validation-error"></span>
            </div>

            <div>
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1.5"></label>
                <textarea asp-for="Description" rows="2"
                          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm resize-none"
                          placeholder="Kısa açıklama"></textarea>
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <div>
                <label asp-for="Content" class="block text-sm font-medium text-gray-700 mb-1.5"></label>
                <textarea asp-for="Content" rows="5"
                          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm resize-none"
                          placeholder="İlan detayları..."></textarea>
                <span asp-validation-for="Content" class="field-validation-error"></span>
            </div>

            <div>
                <label asp-for="ImageFile" class="block text-sm font-medium text-gray-700 mb-1.5">Görsel Yükle</label>
                <input asp-for="ImageFile" type="file" accept="image/*"
                       class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none text-sm bg-white file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:text-xs file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
                <span asp-validation-for="ImageFile" class="field-validation-error"></span>
            </div>

            <div>
                <label asp-for="ImagePath" class="block text-sm font-medium text-gray-700 mb-1.5">veya Görsel URL</label>
                <input asp-for="ImagePath" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm" placeholder="/uploads/..." />
            </div>

            <div class="flex items-center gap-3 pt-2">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-lg text-sm transition-all shadow-sm">
                    İlanı Yayınla
                </button>
                <a asp-action="Index" class="bg-white hover:bg-gray-50 text-gray-700 font-semibold px-6 py-2.5 rounded-lg border border-gray-300 text-sm transition-all">
                    İptal
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
