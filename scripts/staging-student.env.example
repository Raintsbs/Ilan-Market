# Hoca demo / ogrenci projesi — Railway veya Render icin
# ASPNETCORE_ENVIRONMENT=Staging kullanin (Production validator atlanir, demo odeme acik)

ASPNETCORE_ENVIRONMENT=Staging

Jwt__Key=REPLACE_WITH_RANDOM_32_PLUS_CHARS_SECRET
ConnectionStrings__DefaultConnection=Server=sqlserver;Database=AdvertisementAppDb;User Id=sa;Password=Your_strong_Password123;TrustServerCertificate=True;

# Deploy sonrasi gercek URL'lerle guncelleyin
App__FrontendUrl=https://YOUR-FRONTEND.vercel.app
App__ApiUrl=https://YOUR-API.up.railway.app
Cors__AllowedOrigins__0=https://YOUR-FRONTEND.vercel.app

Storage__Provider=Local

Email__Enabled=true
Email__PickupDirectory=email-pickup
Email__From=noreply@ilanmarket.staging

Sms__Provider=dev
Payments__AllowDemo=true
Seed__RunCategoryCatalog=true
