# Production ortam degiskenleri — kopyalayin: production.env
# Gercek degerleri ASLA repoya commit etmeyin.
#
# iyzico callback testi (local): ngrok http 5050 → App__ApiUrl=https://xxx.ngrok-free.app

ASPNETCORE_ENVIRONMENT=Production

# Zorunlu
Jwt__Key=CHANGE_ME_MIN_32_CHARS_RANDOM_SECRET_KEY!!
ConnectionStrings__DefaultConnection=Server=YOUR_SQL;Database=AdvertisementAppDb;User Id=...;Password=...;TrustServerCertificate=True;

# Uygulama URL'leri
App__FrontendUrl=https://www.ornek.com
App__ApiUrl=https://api.ornek.com
Cors__AllowedOrigins__0=https://www.ornek.com

# Azure Blob (Storage:Provider=AzureBlob)
Storage__Provider=AzureBlob
Storage__AzureConnectionString=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
Storage__AzureContainer=uploads
Storage__PublicBaseUrl=https://cdn.ornek.com

# E-posta (SMTP)
Email__Enabled=true
Email__SmtpHost=smtp.ornek.com
Email__SmtpPort=587
Email__UseSsl=true
Email__Username=noreply@ornek.com
Email__Password=SMTP_SIFRE
Email__From=noreply@ornek.com

# SMS — Netgsm (Provider dev OLMAZ)
Sms__Provider=netgsm
Sms__Netgsm__Usercode=NETGSM_KULLANICI
Sms__Netgsm__Password=NETGSM_SIFRE
Sms__Netgsm__MsgHeader=ILANMARKET

# Odeme — demo kapali; iyzico veya Stripe anahtarlari gerekli
Payments__AllowDemo=false
Payments__PreferredProvider=iyzico

# iyzico (Turkiye — production API)
Iyzico__ApiKey=IYZICO_API_KEY
Iyzico__SecretKey=IYZICO_SECRET_KEY
Iyzico__BaseUrl=https://api.iyzipay.com

# Stripe (opsiyonel — uluslararasi / yedek)
Stripe__SecretKey=
Stripe__PublishableKey=
Stripe__WebhookSecret=

# Redis (opsiyonel — yoksa bellek içi cache)
Redis__ConnectionString=

# Cloudflare Turnstile (opsiyonel — bot korumasi)
Captcha__Enabled=true
Captcha__Provider=Turnstile
Captcha__SiteKey=TURNSTILE_SITE_KEY
Captcha__SecretKey=TURNSTILE_SECRET_KEY

# JWT refresh (gun)
Jwt__RefreshTokenDays=30

# Seed — kategori katalogu her restart'ta calismaz
Seed__RunOnStartup=true
Seed__RunCategoryCatalog=false
Seed__RunLegalPages=true
Database__ApplyLegacySqlPatches=false
